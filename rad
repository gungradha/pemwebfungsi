<!-- fungsi -->

<?php
    //fungsi nilai akhir
    function hitungNilaiAkhir($tugas,$uts,$uas){
        $hasil=($tugas*0.3)+($uts*0.3)+($uas*0.4);
        return $hasil;
    }

    //fungsi grade
    function grade($nilaiAkhir){
        if($nilaiAkhir >= 85){
            return "A";
        }elseif($nilaiAkhir >= 75){
            return "B";
        }elseif($nilaiAkhir >= 65){
            return "C";
        }else {
            return "D";
        }
    }

    //fungsi status
    function statusKelulusan($nilaiAkhir){
        if($nilaiAkhir <65){
            return "TIDAK LULUS";
        }else{
            return "LULUS";
        }
    }
?>

